<?xml version="1.0"?>
<robot name="marking_initial">
  <link name="world"/>

  <link name="marking_initial_link">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://so101_description/meshes/marking.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
  </link>

  <joint name="world_to_marking" type="fixed">
    <parent link="world"/>
    <child link="marking_initial_link"/>
  </joint>

  <gazebo reference="marking_initial_link">
    <static>true</static>
    <material>Gazebo/Blue</material>
  </gazebo>
</robot>